<script>
        // Update current date/time
        function updateDateTime() {
            const now = new Date();
            const options = { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' };
            document.getElementById('current-date').textContent = now.toLocaleDateString('en-US', options).replace(',', ' •');
        }
        updateDateTime();
        setInterval(updateDateTime, 60000);

        // Simple tab switching simulation
        const tabs = document.querySelectorAll('button[class*="pb-2"]');
        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                tabs.forEach(t => {
                    t.classList.remove('border-b-2', 'border-primary', 'text-primary', 'font-bold');
                    t.classList.add('text-on-surface-variant');
                });
                tab.classList.add('border-b-2', 'border-primary', 'text-primary', 'font-bold');
                tab.classList.remove('text-on-surface-variant');
            });
        });
    </script>


